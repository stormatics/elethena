{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@xata.io/tsconfig/nextjs.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.mjs", ".next/types/**/*.ts", "images.d.ts"],
  // `playground/` is an experimental Mastra eval harness (run via `pnpm playground`),
  // not part of the shipped app. It still uses the pre-refactor class/sync-registry
  // tool API and is excluded from type-checking until updated. The real eval path is
  // `src/evals` (vitest), which remains fully type-checked.
  "exclude": ["node_modules", "playground"]
}
