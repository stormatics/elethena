# =============================================================================
# Xata Agent (Zafin fork) — production environment template
# Copy to `.env.production` and fill in real values. NEVER commit the real file.
# =============================================================================

# Public URL the app is served from (used for auth callbacks, links in Slack, etc.)
PUBLIC_URL=http://localhost:8080

# --- State database (the agent's own config/state/history store) -------------
# For docker-compose this points at the bundled postgres service.
DATABASE_URL=postgresql://dbagent:changeme@postgres:5432/dbagent

# --- Auth --------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# Optional: bring your own OpenID/OAuth provider
# AUTH_OPENID_ID=
# AUTH_OPENID_SECRET=
# AUTH_OPENID_ISSUER=

# --- LLM provider credentials (set at least one) -----------------------------
OPENAI_API_KEY=
# OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Optional LLM gateways ---------------------------------------------------
# LITELLM_BASE_URL=
# LITELLM_API_KEY=
# OLLAMA_HOST=

# --- MCP ---------------------------------------------------------------------
MCP_SERVERS_DIR=mcp-servers

# --- Scheduler (Zafin fork) --------------------------------------------------
# Shared secret protecting the /api/priv/schedule-tick auth gate. Generate with:
#   openssl rand -hex 32
# Required for safe multi-replica scheduling.
SCHEDULER_SECRET=change-me
# MAX_PARALLEL_RUNS=20
# TIMEOUT_FOR_RUNNING_SCHEDULE_SECS=900
